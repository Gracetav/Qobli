<%- include('../layouts/header') %>

<div class="max-w-md mx-auto my-12 bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
    <div class="gradient-red p-10 text-center text-white">
        <h2 class="text-3xl font-black uppercase tracking-tighter">Login <span class="bg-white/20 px-2 rounded">OI</span></h2>
        <p class="text-red-100 text-sm mt-2 opacity-80">Masukkan akun Anda untuk melanjutkan belanja</p>
    </div>
    
    <form action="/auth/login" method="POST" class="p-10 space-y-6">
        <div>
            <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Email Address</label>
            <input type="email" name="email" required placeholder="example@mail.com" class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-4 focus:ring-red-100 focus:border-red-600 transition-all font-medium text-gray-700 outline-none">
        </div>
        <div>
            <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Password</label>
            <input type="password" name="password" required placeholder="••••••••" class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-4 focus:ring-red-100 focus:border-red-600 transition-all font-medium text-gray-700 outline-none">
        </div>
        <button type="submit" class="w-full gradient-red text-white font-black uppercase tracking-widest py-5 rounded-2xl shadow-xl shadow-red-600/30 hover:scale-[1.02] active:scale-95 transition-all text-sm">Masuk Sekarang</button>
        
        <div class="text-center mt-6">
            <p class="text-gray-500 text-xs font-bold uppercase tracking-wider">Belum punya akun? <a href="/auth/register" class="text-red-600 hover:underline">Daftar Gratis</a></p>
        </div>
    </form>
</div>

<%- include('../layouts/footer') %>
