<%- include('../../layouts/header') %>

<div class="mb-10 flex items-center justify-between">
    <div>
        <h2 class="text-3xl font-black text-gray-900 border-l-8 border-red-600 pl-6 uppercase tracking-tighter">Detail <span class="text-red-600">Pesanan #<%= order.id %></span></h2>
        <p class="text-gray-500 text-sm mt-1 font-medium italic">Informasi lengkap transaksi pembeli</p>
    </div>
    <a href="/admin/orders" class="text-xs font-black uppercase tracking-widest text-gray-400 hover:text-red-600 transition-colors flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Kembali
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <div class="lg:col-span-2 space-y-10">
        <!-- Customer Info -->
        <div class="bg-white p-10 rounded-3xl shadow-xl border border-gray-100 flex items-center justify-between group overflow-hidden relative">
            <div class="absolute right-0 top-0 h-full w-2 bg-red-600 opacity-20 group-hover:opacity-100 transition-all"></div>
            <div>
                <p class="text-[10px] font-black text-red-600 uppercase tracking-widest mb-1">Informasi Pembeli</p>
                <h3 class="text-2xl font-black text-gray-900"><%= order.user_name %></h3>
                <p class="text-gray-500 font-medium"><%= order.user_email %></p>
            </div>
            <div class="text-right">
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Status Saat Ini</p>
                <% 
                    let statusClass = 'bg-yellow-100 text-yellow-700';
                    let statusLabel = order.status;
                    if(order.status === 'pending') {
                        statusClass = 'bg-yellow-100 text-yellow-700';
                        statusLabel = 'AWAITING VERIFICATION';
                    } else if(order.status === 'paid') {
                        statusClass = 'bg-blue-100 text-blue-700';
                        statusLabel = 'PAID';
                    } else if(order.status === 'shipped') {
                        statusClass = 'bg-purple-100 text-purple-700';
                        statusLabel = 'SHIPPED';
                    } else if(order.status === 'completed') {
                        statusClass = 'bg-green-100 text-green-700';
                        statusLabel = 'COMPLETED';
                    } else if(order.status === 'rejected') {
                        statusClass = 'bg-red-100 text-red-700';
                        statusLabel = 'REJECTED';
                    } else if(order.status === 'cancelled') {
                        statusClass = 'bg-gray-100 text-gray-700';
                        statusLabel = 'CANCELLED';
                    }
                %>
                <span class="<%= statusClass %> px-6 py-2 rounded-full text-xs font-black uppercase tracking-tighter border border-current shadow-lg"><%= statusLabel %></span>
            </div>
        </div>

        <!-- Items -->
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
            <div class="bg-gray-900 text-white px-10 py-5">
                <h4 class="text-xs font-black uppercase tracking-widest">Detail Item Dibeli</h4>
            </div>
            <div class="p-10 space-y-8">
                <% items.forEach(item => { %>
                    <div class="flex items-center gap-6 pb-6 border-b border-gray-100 last:border-0 last:pb-0">
                        <div class="h-20 w-20 bg-gray-50 rounded-2xl overflow-hidden p-1 border border-gray-100 shrink-0">
                            <% if(item.product_image) { %>
                                <img src="/uploads/products/<%= item.product_image %>" class="h-full w-full object-contain">
                            <% } %>
                        </div>
                        <div class="flex-grow">
                            <h5 class="text-lg font-black text-gray-900 uppercase tracking-tight"><%= item.product_name %></h5>
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Jumlah: <%= item.qty %> items</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xl font-black text-red-600"><%= formatCurrency(item.price * item.qty) %></p>
                            <p class="text-[10px] text-gray-400 font-bold italic">@<%= formatCurrency(item.price) %></p>
                        </div>
                    </div>
                <% }) %>
                <div class="pt-8 flex justify-between items-center border-t-2 border-dashed border-gray-200">
                    <p class="text-xl font-black text-gray-900 uppercase tracking-tighter">Total Pembayaran</p>
                    <p class="text-3xl font-black text-red-600"><%= formatCurrency(order.total_price) %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions & Payment -->
    <div class="space-y-10">
        <div class="bg-white p-10 rounded-3xl shadow-xl border border-gray-100">
            <h4 class="text-xs font-black text-gray-900 uppercase tracking-widest mb-8 border-b pb-4">Bukti Transfer</h4>
            <% if(payment && payment.proof) { %>
                <div class="rounded-2xl overflow-hidden border-2 border-gray-100 group relative">
                    <img src="/uploads/payments/<%= payment.proof %>" class="w-full h-auto transform group-hover:scale-105 transition-transform duration-500">
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                        <a href="/uploads/payments/<%= payment.proof %>" target="_blank" class="bg-white text-gray-900 px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-xl transform scale-90 group-hover:scale-100 transition-all">Lihat Full</a>
                    </div>
                </div>
                <p class="text-center text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-4">Klik gambar untuk memperbesar</p>
            <% } else { %>
                <div class="bg-gray-50 border-2 border-dashed border-gray-200 rounded-3xl py-20 px-6 text-center">
                    <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a2 2 0 002-2V5a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <p class="text-xs text-gray-400 font-black uppercase tracking-widest">Bukti Belum Diupload</p>
                </div>
            <% } %>
        </div>

        <div class="bg-gray-900 p-10 rounded-3xl shadow-2xl text-white">
            <h4 class="text-xs font-black text-gray-500 uppercase tracking-widest mb-8 border-b border-gray-800 pb-4">Update Status</h4>
            <form action="/admin/orders/<%= order.id %>/status" method="POST" class="space-y-4">
                <div class="space-y-4">
                    <label class="flex items-center gap-4 cursor-pointer group">
                        <input type="radio" name="status" value="paid" class="w-6 h-6 border-gray-700 bg-gray-800 text-blue-600 focus:ring-blue-500 focus:ring-offset-gray-900" <%= order.status === 'paid' ? 'checked' : '' %>>
                        <span class="text-sm font-black uppercase tracking-widest group-hover:text-blue-500 transition-colors">Confirm Payment</span>
                    </label>
                    <label class="flex items-center gap-4 cursor-pointer group">
                        <input type="radio" name="status" value="shipped" class="w-6 h-6 border-gray-700 bg-gray-800 text-purple-600 focus:ring-purple-500 focus:ring-offset-gray-900" <%= order.status === 'shipped' ? 'checked' : '' %>>
                        <span class="text-sm font-black uppercase tracking-widest group-hover:text-purple-500 transition-colors">Kirim Barang</span>
                    </label>
                    <label class="flex items-center gap-4 cursor-pointer group">
                        <input type="radio" name="status" value="completed" class="w-6 h-6 border-gray-700 bg-gray-800 text-green-600 focus:ring-green-500 focus:ring-offset-gray-900" <%= order.status === 'completed' ? 'checked' : '' %>>
                        <span class="text-sm font-black uppercase tracking-widest group-hover:text-green-500 transition-colors">Selesai</span>
                    </label>
                    <label class="flex items-center gap-4 cursor-pointer group">
                        <input type="radio" name="status" value="rejected" class="w-6 h-6 border-gray-700 bg-gray-800 text-red-600 focus:ring-red-500 focus:ring-offset-gray-900" <%= order.status === 'rejected' ? 'checked' : '' %>>
                        <span class="text-sm font-black uppercase tracking-widest group-hover:text-red-500 transition-colors">Reject</span>
                    </label>
                    <label class="flex items-center gap-4 cursor-pointer group">
                        <input type="radio" name="status" value="cancelled" class="w-6 h-6 border-gray-700 bg-gray-800 text-gray-600 focus:ring-gray-500 focus:ring-offset-gray-900" <%= order.status === 'cancelled' ? 'checked' : '' %>>
                        <span class="text-sm font-black uppercase tracking-widest group-hover:text-gray-500 transition-colors">Cancel Transaction</span>
                    </label>
                </div>
                <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white py-4 rounded-2xl font-black uppercase tracking-widest text-[10px] mt-8 shadow-xl shadow-red-900/40 transition-all active:scale-95">Update Transaksi</button>
            </form>
        </div>
    </div>
</div>

<%- include('../../layouts/footer') %>
