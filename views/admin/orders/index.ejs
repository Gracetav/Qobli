<%- include('../../layouts/header') %>

<div class="mb-10">
    <h2 class="text-3xl font-black text-gray-900 border-l-8 border-red-600 pl-6 uppercase tracking-tighter">Manajemen <span class="text-red-600">Pesanan</span></h2>
    <p class="text-gray-500 text-sm mt-1 font-medium italic">Lacak dan verifikasi transaksi masuk</p>
</div>

<div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-gray-900 text-white uppercase text-[10px] font-black tracking-widest">
                    <th class="px-8 py-5">Tgl Pesan</th>
                    <th class="px-8 py-5">Customer</th>
                    <th class="px-8 py-5">Total Harga</th>
                    <th class="px-8 py-5">Status</th>
                    <th class="px-8 py-5 text-center">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 font-medium">
                <% orders.forEach(order => { %>
                    <tr class="hover:bg-red-50/30 transition-colors">
                        <td class="px-8 py-5 text-gray-400 text-xs"><%= new Date(order.created_at).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %></td>
                        <td class="px-8 py-5 text-gray-900 font-bold"><%= order.user_name %></td>
                        <td class="px-8 py-5 text-red-600 font-black"><%= formatCurrency(order.total_price) %></td>
                        <td class="px-8 py-5">
                            <% 
                                let statusClass = 'bg-yellow-100 text-yellow-700';
                                let statusLabel = order.status;
                                if(order.status === 'pending') {
                                    statusClass = 'bg-yellow-100 text-yellow-700';
                                    statusLabel = 'AWAITING VERIFICATION';
                                } else if(order.status === 'paid') {
                                    statusClass = 'bg-blue-100 text-blue-700';
                                    statusLabel = 'PAID';
                                } else if(order.status === 'shipped') {
                                    statusClass = 'bg-purple-100 text-purple-700';
                                    statusLabel = 'SHIPPED';
                                } else if(order.status === 'completed') {
                                    statusClass = 'bg-green-100 text-green-700';
                                    statusLabel = 'COMPLETED';
                                } else if(order.status === 'rejected') {
                                    statusClass = 'bg-red-100 text-red-700';
                                    statusLabel = 'REJECTED';
                                } else if(order.status === 'cancelled') {
                                    statusClass = 'bg-gray-100 text-gray-700';
                                    statusLabel = 'CANCELLED';
                                }
                            %>
                            <span class="<%= statusClass %> px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-current shadow-sm">
                                <%= statusLabel %>
                            </span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <a href="/admin/orders/<%= order.id %>" class="bg-gray-900 text-white px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg hover:bg-red-600 transition-colors transform active:scale-95 inline-block">Detail Pesanan</a>
                        </td>
                    </tr>
                <% }) %>
                <% if(orders.length === 0) { %>
                    <tr>
                        <td colspan="5" class="py-20 text-center text-gray-400 font-bold uppercase tracking-widest text-sm">Belum ada pesanan masuk</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../../layouts/footer') %>
