<%- include('../../layouts/header') %>

<div class="mb-10">
    <h2 class="text-3xl font-black text-gray-900 border-l-8 border-red-600 pl-6 uppercase tracking-tighter">Manajemen <span class="text-red-600">User</span></h2>
    <p class="text-gray-500 text-sm mt-1 font-medium italic">Daftar pengguna terdaftar di sistem</p>
</div>

<div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-gray-900 text-white uppercase text-[10px] font-black tracking-widest">
                    <th class="px-8 py-5">Nama Lengkap</th>
                    <th class="px-8 py-5">Email</th>
                    <th class="px-8 py-5">Role</th>
                    <th class="px-8 py-5 text-center">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 font-medium">
                <% users.forEach(u => { %>
                    <tr class="hover:bg-red-50/30 transition-colors">
                        <td class="px-8 py-5 text-gray-900"><%= u.name %></td>
                        <td class="px-8 py-5 text-gray-500"><%= u.email %></td>
                        <td class="px-8 py-5">
                            <span class="bg-blue-100 px-3 py-1 rounded-full text-xs font-bold text-blue-600 uppercase tracking-widest"><%= u.role %></span>
                        </td>
                        <td class="px-8 py-5">
                            <div class="flex justify-center">
                                <a href="/admin/users/delete/<%= u.id %>" onclick="return confirm('Hapus user ini?')" class="bg-red-600 hover:bg-red-700 text-white p-3 rounded-2xl shadow-lg shadow-red-600/20 transition-all active:scale-95">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../../layouts/footer') %>
