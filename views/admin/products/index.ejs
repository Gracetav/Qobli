<%- include('../../layouts/header') %>

<div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div>
        <h2 class="text-3xl font-black text-gray-900 border-l-8 border-red-600 pl-6 uppercase tracking-tighter">Manajemen <span class="text-red-600">Produk</span></h2>
        <p class="text-gray-500 text-sm mt-1 font-medium italic">Kelola stok dan katalog sparepart</p>
    </div>
    <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-red-600 hover:bg-red-700 text-white font-black text-xs uppercase tracking-widest px-8 py-4 rounded-2xl shadow-xl shadow-red-600/30 transition-all flex items-center gap-2 transform active:scale-95">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tambah Produk
    </button>
</div>

<div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-gray-900 text-white uppercase text-[10px] font-black tracking-widest">
                    <th class="px-8 py-5">Gambar</th>
                    <th class="px-8 py-5">Nama Produk</th>
                    <th class="px-8 py-5">Harga</th>
                    <th class="px-8 py-5">Stok</th>
                    <th class="px-8 py-5 text-center">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 font-medium">
                <% products.forEach(product => { %>
                    <tr class="hover:bg-red-50/30 transition-colors">
                        <td class="px-8 py-5">
                            <div class="h-16 w-16 bg-gray-50 rounded-xl overflow-hidden p-1 border border-gray-200">
                                <% if(product.image) { %>
                                    <img src="/uploads/products/<%= product.image %>" class="h-full w-full object-contain">
                                <% } else { %>
                                    <div class="h-full w-full bg-gray-200 flex items-center justify-center text-[10px] text-gray-400 font-black">N/A</div>
                                <% } %>
                            </div>
                        </td>
                        <td class="px-8 py-5 text-gray-900"><%= product.name %></td>
                        <td class="px-8 py-5 text-red-600 font-black">Rp<%= product.price.toLocaleString('id-ID') %></td>
                        <td class="px-8 py-5"><span class="bg-gray-100 px-3 py-1 rounded-full text-xs font-bold text-gray-600"><%= product.stock %> items</span></td>
                        <td class="px-8 py-5">
                            <div class="flex items-center justify-center gap-3">
                                <button onclick="editProduct('<%= JSON.stringify(product) %>')" class="bg-blue-600 hover:bg-blue-700 text-white p-3 rounded-2xl shadow-lg shadow-blue-600/20 transition-all active:scale-95">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </button>
                                <a href="/admin/products/delete/<%= product.id %>" onclick="return confirm('Hapus produk ini?')" class="bg-red-600 hover:bg-red-700 text-white p-3 rounded-2xl shadow-lg shadow-red-600/20 transition-all active:scale-95">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div id="addModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-6">
    <div class="bg-white w-full max-w-xl rounded-3xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
        <div class="gradient-red px-10 py-6 text-white flex justify-between items-center">
            <h3 class="text-xl font-black uppercase tracking-tighter">Tambah Produk Baru</h3>
            <button onclick="document.getElementById('addModal').classList.add('hidden')" class="text-white/70 hover:text-white transition-colors">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="p-10 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="col-span-full">
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Nama Produk</label>
                    <input type="text" name="name" required class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-red-600 transition-all font-medium">
                </div>
                <div>
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Harga (Rp)</label>
                    <input type="number" name="price" required class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-red-600 transition-all font-medium">
                </div>
                <div>
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Stok</label>
                    <input type="number" name="stock" required class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-red-600 transition-all font-medium">
                </div>
                <div class="col-span-full">
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Deskripsi</label>
                    <textarea name="description" rows="3" class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-red-600 transition-all font-medium"></textarea>
                </div>
                <div class="col-span-full">
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Gambar Produk</label>
                    <input type="file" name="image" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-red-50 file:text-red-700 hover:file:bg-red-100 cursor-pointer">
                </div>
            </div>
            <button type="submit" class="w-full gradient-red text-white py-4 rounded-2xl font-black uppercase tracking-widest text-xs shadow-xl shadow-red-600/30 active:scale-95 transition-all">Simpan Produk</button>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-6">
    <div class="bg-white w-full max-w-xl rounded-3xl shadow-2xl overflow-hidden">
        <div class="bg-blue-600 px-10 py-6 text-white flex justify-between items-center">
            <h3 class="text-xl font-black uppercase tracking-tighter">Edit Produk</h3>
            <button onclick="document.getElementById('editModal').classList.add('hidden')" class="text-white/70 hover:text-white transition-colors">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <form id="editForm" action="" method="POST" enctype="multipart/form-data" class="p-10 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="col-span-full">
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Nama Produk</label>
                    <input type="text" name="name" id="editName" required class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-blue-600 transition-all font-medium">
                </div>
                <div>
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Harga (Rp)</label>
                    <input type="number" name="price" id="editPrice" required class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-blue-600 transition-all font-medium">
                </div>
                <div>
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Stok</label>
                    <input type="number" name="stock" id="editStock" required class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-blue-600 transition-all font-medium">
                </div>
                <div class="col-span-full">
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Deskripsi</label>
                    <textarea name="description" id="editDesc" rows="3" class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-2xl outline-none focus:border-blue-600 transition-all font-medium"></textarea>
                </div>
                <div class="col-span-full">
                    <label class="block text-xs font-black text-gray-900 uppercase tracking-widest mb-2">Ganti Gambar (Opsional)</label>
                    <input type="file" name="image" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer">
                </div>
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-black uppercase tracking-widest text-xs shadow-xl shadow-blue-600/30 active:scale-95 transition-all">Update Produk</button>
        </form>
    </div>
</div>

<script>
    function editProduct(productStr) {
        const product = JSON.parse(productStr);
        document.getElementById('editForm').action = '/admin/products/edit/' + product.id;
        document.getElementById('editName').value = product.name;
        document.getElementById('editPrice').value = product.price;
        document.getElementById('editStock').value = product.stock;
        document.getElementById('editDesc').value = product.description;
        document.getElementById('editModal').classList.remove('hidden');
    }
</script>

<%- include('../../layouts/footer') %>
