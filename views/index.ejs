<%- include('layouts/header') %>

<div class="mb-12 bg-gray-900 rounded-3xl overflow-hidden shadow-2xl relative">
    <div class="h-[400px] bg-gradient-to-br from-red-700 via-red-600 to-gray-900 absolute inset-0 opacity-80 mix-blend-overlay"></div>
    <div class="relative z-10 p-12 md:p-24 text-center max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 uppercase tracking-tighter drop-shadow-2xl">Pusat Sparepart <span class="bg-red-500 text-transparent bg-clip-text drop-shadow-[0_2px_10px_rgba(239,68,68,0.5)]">OI</span></h1>
        <p class="text-lg md:text-xl text-gray-300 font-medium leading-relaxed max-w-2xl mx-auto mb-10">Penyedia Komponen Otomotif Terlengkap dengan Standar Kualitas Profesional. Performa Maksimal untuk Kendaraan Anda.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="#katalog" class="bg-white text-gray-900 px-10 py-4 rounded-2xl font-bold uppercase tracking-widest text-sm hover:bg-gray-100 transform active:scale-95 transition-all shadow-xl shadow-white/10 group-hover:scale-105">Belanja Sekarang</a>
            <div class="flex items-center gap-3 text-red-100/80 font-bold uppercase tracking-wider text-xs">
                <span class="w-10 h-[2px] bg-red-500"></span>
                <span>Kualitas Terjamin 100%</span>
            </div>
        </div>
    </div>
</div>

<div id="katalog" class="flex items-center justify-between mb-10 pb-6 border-b border-gray-200">
    <div>
        <h2 class="text-3xl font-black text-gray-900 uppercase tracking-tight">Katalog <span class="text-red-600">Produk</span></h2>
        <p class="text-gray-500 text-sm mt-1">Daftar sparepart motor terbaru tersedia saat ini</p>
    </div>
    <div class="hidden sm:flex gap-4">
        <div class="bg-white border border-gray-200 px-6 py-2 rounded-xl text-xs font-bold uppercase tracking-widest text-gray-400 shadow-sm">Terbaru</div>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
    <% products.forEach(product => { %>
        <div class="group bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-red-100 transform hover:-translate-y-2 flex flex-col h-full">
            <div class="relative h-64 overflow-hidden bg-gray-50 flex items-center justify-center p-4">
                <% if(product.image) { %>
                    <img src="/uploads/products/<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-contain mix-blend-multiply group-hover:scale-110 transition-transform duration-700">
                <% } else { %>
                    <div class="bg-gray-200 w-full h-full flex flex-col items-center justify-center text-gray-400">
                        <svg class="w-16 h-16 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <span class="text-[10px] mt-2 font-bold uppercase tracking-widest">No Image</span>
                    </div>
                <% } %>
                <div class="absolute top-4 left-4">
                    <span class="bg-white/90 backdrop-blur text-red-600 font-black text-[10px] px-3 py-1.5 rounded-full shadow-lg border border-red-500 uppercase tracking-widest">Premium quality</span>
                </div>
            </div>
            <div class="p-6 flex flex-col flex-grow bg-white">
                <div class="mb-4">
                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-red-600 transition-colors line-clamp-1"><%= product.name %></h3>
                    <p class="text-xs text-gray-500 mt-1 font-medium bg-gray-100 inline-block px-2 py-0.5 rounded uppercase tracking-wider">Stok: <%= product.stock %></p>
                </div>
                <div class="mt-auto">
                    <div class="flex items-center gap-1 mb-6">
                        <span class="text-red-600 font-black text-2xl"><%= formatCurrency(product.price) %></span>
                    </div>
                    <div class="flex gap-2">
                        <a href="/user/products/<%= product.id %>" class="flex-grow bg-white border-2 border-red-600 text-red-600 font-bold px-4 py-3 rounded-2xl text-center hover:bg-red-50 transform active:scale-95 transition-all text-xs uppercase tracking-widest shadow-xl shadow-red-500/5">Detail</a>
                        <% if (user) { %>
                        <form action="/user/cart/add" method="POST">
                            <input type="hidden" name="product_id" value="<%= product.id %>">
                            <input type="hidden" name="qty" value="1">
                            <button type="submit" class="bg-red-600 text-white px-5 py-3 rounded-2xl hover:bg-red-700 transform active:scale-95 transition-all shadow-xl shadow-red-600/30">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                            </button>
                        </form>
                        <% } else { %>
                        <a href="/auth/login" class="bg-gray-800 text-white px-5 py-3 rounded-2xl hover:bg-red-600 transform active:scale-95 transition-all shadow-xl flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
                        </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
    <% if(products.length === 0) { %>
        <div class="col-span-full py-20 text-center">
            <div class="bg-gray-100 inline-block p-10 rounded-full mb-6">
                <svg class="w-20 h-20 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900">Belum ada produk</h3>
            <p class="text-gray-500 mt-2">Katalog kami sedang dalam pembaruan.</p>
        </div>
    <% } %>
</div>

<%- include('layouts/footer') %>
